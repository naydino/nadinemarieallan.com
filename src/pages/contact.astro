---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="contact">
  <section class="contact">
    <span class="eyebrow">contact</span>
    <p class="body-md line">for collaboration, commissions, or enquiries:</p>
    <a class="cta-link email" href="mailto:nadinemarieallan@gmail.com">nadinemarieallan@gmail.com</a>

    <div class="elsewhere">
      <span class="eyebrow">elsewhere</span>
      <div class="social-links">
        <a class="cta-link" href="https://github.com/naydino" target="_blank" rel="noopener noreferrer">github → naydino</a>
        <a class="cta-link" href="https://www.instagram.com/naydino" target="_blank" rel="noopener noreferrer">instagram → @naydino</a>
        <a class="cta-link" href="https://www.linkedin.com/in/nadinemarie/" target="_blank" rel="noopener noreferrer">linkedin → nadinemarie</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-7) var(--page-padding-x) var(--space-8);
  }
  .line {
    margin-top: var(--space-3);
  }
  .email {
    display: inline-block;
    margin-top: var(--space-4);
    font-size: var(--text-md);
  }
  .elsewhere {
    margin-top: var(--space-6);
  }
  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  @media (max-width: 600px) {
    .contact { padding: var(--space-6) var(--page-padding-x-sm) var(--space-7); }
  }
</style>
