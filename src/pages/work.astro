---
import BaseLayout from '../layouts/BaseLayout.astro';

const groups = [
  {
    year: '2025',
    projects: [
      { title: 'The Oracle That Wears Us', slug: 'oracle', medium: 'installation', venue: 'IADE', image: '/images/oracle/oracle_installation_room.png', live: true },
      { title: 'Echo Garden', slug: 'echo-garden', medium: 'generative-media', venue: 'IADE – Universidade Europeia', image: '/images/echo-garden/hero.jpg', live: false },
      { title: 'Snakeskin Jacket', slug: 'snakeskin', medium: 'experimental-multimedia', venue: 'Cucalorus Film Festival', image: '/images/snakeskin/IMG_5543.jpg', live: false },
    ],
  },
  {
    year: '2022',
    projects: [
      { title: 'Metropolis Unrestored', slug: 'metropolis', medium: 'experimental-multimedia', venue: 'Fantastic Fest', image: '/images/metropolis/IMG_0530.JPG', live: false },
      { title: 'Nosfera2', slug: 'nosfera2', medium: 'installation', venue: 'Overlook Film Festival', image: '/images/nosfera2/IMG_8685.JPG', live: false },
    ],
  },
  {
    year: '2021',
    projects: [
      { title: '#0000FF Velvet', slug: 'velvet', medium: 'installation', venue: 'Cucalorus Film Festival', image: '/images/velvet/762AE461-32C8-4926-97F3-725645EE5864.jpg', live: false },
      { title: 'Digital Debris Gallery', slug: 'digital-debris', medium: 'video-performance', venue: 'Digital Debris Gallery', image: '/images/digital-debris/60FC88AD-A873-4275-B0B4-1F003B61B431.jpg', live: false },
    ],
  },
];

const filters = [
  { label: 'all', value: 'all' },
  { label: 'installation', value: 'installation' },
  { label: 'generative media', value: 'generative-media' },
  { label: 'experimental multimedia', value: 'experimental-multimedia' },
  { label: 'video & performance', value: 'video-performance' },
  { label: 'fine art', value: 'fine-art' },
];
---

<BaseLayout title="work">
  <section class="work">
    <header class="work-head">
      <div class="filter-meta">
        <span class="eyebrow">filter by medium</span>
      </div>
      <div class="filter-tabs" role="group" aria-label="filter by medium">
        {filters.map((f) => (
          <button
            class={`tag filter-tab${f.value === 'all' ? ' active' : ''}`}
            data-filter={f.value}
          >
            {f.label}
          </button>
        ))}
      </div>
    </header>

    <div class="work-groups">
      {groups.map((group) => (
        <div class="year-group" data-year={group.year}>
          <div class="year-header">
            <span class="eyebrow year-eyebrow">{group.year}</span>
          </div>
          <div class="cells-grid">
            {group.projects.map((project) => (
              project.live ? (
                <a
                  href={`/work/${project.slug}`}
                  class="project-cell"
                  data-medium={project.medium}
                >
                  <div class="cell-image">
                    <img
                      src={project.image}
                      alt={project.title}
                      class="cell-img"
                      onerror="this.style.display='none'"
                    />
                  </div>
                  <div class="cell-meta">
                    <span class="year-label">{group.year}</span>
                    <div class="cell-title display-lg">{project.title}</div>
                    <div class="cell-venue">{project.venue}</div>
                    <div class="cell-tags">
                      <span class="tag">{project.medium.replace(/-/g, ' ')}</span>
                    </div>
                  </div>
                </a>
              ) : (
                <div
                  class="project-cell no-link"
                  data-medium={project.medium}
                >
                  <div class="cell-image">
                    <img
                      src={project.image}
                      alt={project.title}
                      class="cell-img"
                      onerror="this.style.display='none'"
                    />
                  </div>
                  <div class="cell-meta">
                    <span class="year-label">{group.year}</span>
                    <div class="cell-title display-lg">{project.title}</div>
                    <div class="cell-venue">{project.venue}</div>
                    <div class="cell-tags">
                      <span class="tag">{project.medium.replace(/-/g, ' ')}</span>
                    </div>
                    <div class="cell-coming-soon">page coming soon</div>
                  </div>
                </div>
              )
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cells = document.querySelectorAll<HTMLElement>('.project-cell');
  const yearGroups = document.querySelectorAll<HTMLElement>('.year-group');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter!;

      cells.forEach((cell) => {
        if (filter === 'all' || cell.dataset.medium === filter) {
          cell.classList.remove('hidden');
        } else {
          cell.classList.add('hidden');
        }
      });

      yearGroups.forEach((group) => {
        const visible = group.querySelectorAll('.project-cell:not(.hidden)');
        group.classList.toggle('hidden', visible.length === 0);
      });
    });
  });
</script>

<style>
  .hidden { display: none; }

  .work {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-6) var(--page-padding-x) var(--space-7);
  }
  .work-head {
    margin-bottom: var(--space-5);
  }
  .filter-meta {
    margin-bottom: var(--space-2);
  }
  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  .filter-tab {
    cursor: pointer;
  }

  .year-group {
    margin-bottom: var(--space-5);
  }
  .year-header {
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }
  .year-eyebrow {
    color: var(--muted);
  }

  .cells-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .project-cell {
    display: block;
    text-decoration: none;
    transition: transform var(--transition-base);
  }
  .project-cell:not(.no-link):hover {
    transform: translateY(-3px);
  }
  .no-link {
    cursor: default;
  }
  .cell-image {
    background: var(--surface);
    overflow: hidden;
    margin-bottom: var(--space-2);
    min-height: 200px;
  }
  .cell-img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
    transition: filter var(--transition-slow);
  }
  .project-cell:not(.no-link):hover .cell-img {
    filter: grayscale(0%);
  }
  .cell-meta {
    padding: 0 2px;
  }
  .year-label {
    display: block;
    margin-bottom: 4px;
  }
  .cell-title {
    color: var(--ink);
    transition: color var(--transition-base);
    margin: 0;
  }
  .project-cell:not(.no-link):hover .cell-title {
    color: var(--gold);
  }
  .cell-venue {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--w-light);
    color: var(--muted);
    margin-top: 4px;
  }
  .cell-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: var(--space-1);
  }
  .cell-coming-soon {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--w-light);
    color: var(--muted);
    letter-spacing: var(--ls-base);
    margin-top: 6px;
    font-style: italic;
  }

  @media (max-width: 600px) {
    .work {
      padding: var(--space-5) var(--page-padding-x-sm) var(--space-6);
    }
    .cells-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
