---

<BaseLayout title="cv">
  <section class="cv">
    <div class="cv-head">
      <span class="eyebrow">curriculum vitae</span>
      <div class="name-display">nadine marie allan</div>
      <a class="cta-link download-link" href="/files/nadine-marie-allan-cv.pdf">download cv ↓</a>
    </div>

    <hr class="rule" />

    {sections.map((section) => (
      <div class="cv-section">
        <h2 class="eyebrow section-title">{section.title}</h2>
        <div class="entries">
          {section.entries.map((entry) => {
            const parsed = parseEntry(entry);
            return (
              <div class="entry">
                {parsed.year && <span class="year-label entry-year">{parsed.year}</span>}
                <span set:html={parsed.html} />
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>

