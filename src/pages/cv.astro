---
import BaseLayout from '../layouts/BaseLayout.astro';

function parseEntry(text: string): { year?: string; html: string } {
  const m = text.match(/^(\d{4}) — ([\s\S]*)/);
  const year = m ? m[1] : undefined;
  const rest = m ? m[2] : text;
  const html = rest.replace(/\*([^*]+)\*/g, '<em>$1</em>');
  return { year, html };
}

