---
import BaseLayout from '../layouts/BaseLayout.astro';

const featured = [
  {
    title: 'The Oracle That Wears Us',
    descriptor: 'interactive AI installation · 2025',
    image: '/images/oracle/hero.jpg',
    href: '/work/oracle',
  },
  {
    title: 'Echo Garden',
    descriptor: 'generative p5.js environment · 2025',
    image: '/images/echo-garden/hero.jpg',
    href: '#',
  },
  {
    title: '#0000FF Velvet',
    descriptor: 'projection mapping, installation · 2021',
    image: '/images/velvet/1A0E5F07-2C5F-4948-92B5-AFCB4F97C6FE.jpg',
    href: '#',
  },
];
---

<BaseLayout title="home">
  <section class="hero">
    <span class="eyebrow">artist & creative technologist — lisbon</span>
    <h1 class="display-xl hero-statement">
      What does a system do to a thing when it tries to understand it?
    </h1>
    <hr class="type-divider" />
    <p class="bio">
      Based in Lisbon, completing an MA in Creative Computing and AI at IADE – Universidade Europeia. I work in installation, generative media, video, and sound — tracing what gets lost, added, or transformed in translation.
    </p>
    <div class="links-row">
      <a class="cta-link" href="/work">view work →</a>
      <a class="cta-link" href="/about">about</a>
    </div>
  </section>

  <section class="featured">
    <div class="featured-head">
      <hr class="rule" />
      <span class="eyebrow">selected work</span>
    </div>
    <div class="featured-grid">
      {featured.map((project) => (
        <a href={project.href} class="project-cell">
          <div class="cell-image">
            <img
              src={project.image}
              alt={project.title}
              class="cell-img"
              onerror="this.style.display='none'"
            />
          </div>
          <div class="cell-title display-md">{project.title}</div>
          <div class="cell-descriptor">{project.descriptor}</div>
        </a>
      ))}
    </div>
    <div class="featured-cta">
      <a class="cta-link" href="/work">view all work →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-7) var(--page-padding-x) var(--space-6);
  }
  .hero-statement {
    margin-top: var(--space-3);
    max-width: 640px;
  }
  .type-divider {
    margin: var(--space-3) 0;
  }
  .bio {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: var(--w-light);
    line-height: var(--lh-body);
    color: var(--mid);
    max-width: 560px;
    margin: 0;
  }
  .links-row {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .featured {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--page-padding-x) var(--space-7);
  }
  .featured-head {
    margin-bottom: var(--space-4);
  }
  .featured-head .rule {
    margin-bottom: var(--space-3);
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .project-cell {
    display: block;
    text-decoration: none;
    transition: transform var(--transition-base);
  }
  .project-cell:hover {
    transform: translateY(-3px);
  }
  .cell-image {
    background: var(--surface);
    overflow: hidden;
    margin-bottom: var(--space-2);
    min-height: 180px;
  }
  .cell-img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
    transition: filter var(--transition-slow);
  }
  .project-cell:hover .cell-img {
    filter: grayscale(0%);
  }
  .cell-title {
    transition: color var(--transition-base);
  }
  .project-cell:hover .cell-title {
    color: var(--gold);
  }
  .cell-descriptor {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--w-light);
    color: var(--muted);
    margin-top: 4px;
  }
  .featured-cta {
    text-align: right;
    margin-top: var(--space-4);
  }

  @media (max-width: 768px) {
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .hero {
      padding: var(--space-6) var(--page-padding-x-sm) var(--space-5);
    }
    .featured {
      padding: 0 var(--page-padding-x-sm) var(--space-6);
    }
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
